{
  "name": "link-me-frontend",
  "private": true,
  "version": "0.0.0",
  "packageManager": "npm@11.13.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run build:shared && next dev --turbopack -p 3000",
    "dev:pwa": "npm run build:shared && ENABLE_PWA=1 next dev -p 3000",
    "build:shared": "npm run build -w @link-me/shared",
    "build": "npm run build:shared && next build",
    "start": "next start -p 3000",
    "preview:pwa": "npm run build && npm start",
    "lint": "oxlint src"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@link-me/shared": "*",
    "@serwist/next": "^9.5.11",
    "@tanstack/react-query": "^5.83.0",
    "agora-extension-beauty-effect": "^1.0.2-beta",
    "agora-rtc-sdk-ng": "^4.23.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.23.0",
    "next": "^15.3.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.7.0",
    "serwist": "^9.5.11",
    "shadcn": "^4.13.0",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "oxlint": "^1.71.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2"
  }
}

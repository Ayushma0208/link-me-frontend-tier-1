# --- Local development (backend on :4000) ---
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
API_URL=http://localhost:4000

# --- Production example ---
# API_URL=https://api.yourdomain.com
# NEXT_PUBLIC_API_URL=/api
# NEXT_PUBLIC_SOCKET_URL=https://api.yourdomain.com

NEXT_PUBLIC_RAZORPAY_KEY_ID=
NEXT_PUBLIC_AGORA_APP_ID=

# Google Identity (OAuth) — Web client ID from Google Cloud Console
# Must match backend GOOGLE_CLIENT_ID
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Admin WhatsApp for brand collab inquiries (digits only, country code, no +)
# Example India: 919876543210
NEXT_PUBLIC_ADMIN_WHATSAPP_NUMBER=

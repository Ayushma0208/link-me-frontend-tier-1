# Host port published by docker compose (browser: http://PUBLIC_IP:$HOST_PORT)
HOST_PORT=3021

# Server-side rewrite target (Docker network → backend container)
API_URL=http://link-me-backend:4000

# Browser → this frontend (Next rewrites /api to API_URL)
NEXT_PUBLIC_API_URL=/api

# Browser → backend sockets (must be reachable from the user's device, not localhost)
NEXT_PUBLIC_SOCKET_URL=http://YOUR_PUBLIC_IP:4000

NEXT_PUBLIC_RAZORPAY_KEY_ID=
NEXT_PUBLIC_AGORA_APP_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_ADMIN_WHATSAPP_NUMBER=
